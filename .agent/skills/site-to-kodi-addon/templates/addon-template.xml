<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.{addon_id}" name="{addon_name}" version="0.0.1" provider-name="{author}">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.25.1"/>
    <import addon="script.module.beautifulsoup4" version="4.9.3"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="{entry_file}.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es">{summary}</summary>
    <description lang="es">{description}</description>
    <platform>all</platform>
    <language>es</language>
    <license>GPL-3.0</license>
    <assets>
      <icon>resources/img/icon.png</icon>
      <fanart>resources/img/fanart.jpg</fanart>
    </assets>
  </extension>
</addon>